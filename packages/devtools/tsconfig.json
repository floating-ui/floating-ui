{
  "extends": "config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc",
    "baseUrl": ".",
    "paths": {
      "@floating-ui/dom": ["../dom/src/index.ts"],
      "@floating-ui/dom/*": ["../dom/src/*"],
      "extension": ["../../extension/src/index.ts"],
      "extension/*": ["../../extension/src/*"]
    },
    // TODO: move to config/tsconfig.base.json after https://github.com/vitejs/vite/issues/21715 is resolved.
    "exactOptionalPropertyTypes": true
  },
  "include": ["src"],
  "references": [
    {"path": "../dom/tsconfig.lib.json"},
    {"path": "../../extension/tsconfig.lib.json"}
  ]
}
